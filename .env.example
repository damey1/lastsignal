# ── Wallet (REQUIRED for deployment) ──
# NEVER share this or commit .env
PRIVATE_KEY=__YOUR_WALLET_PRIVATE_KEY__

# ── Ritual Chain RPC ──
RITUAL_RPC_URL=https://rpc.ritualfoundation.org

# ── Optional: Previous CheckIn override ──
# Only set this if deploying with a specific migration source
# PREVIOUS_CHECKIN_ADDRESS=0x...
