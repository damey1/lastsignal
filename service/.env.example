# ═══════════════════════════════════════════════════════════
# LastSignal Notification Service — Environment Variables
# ═══════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp service/.env.example service/.env
#
# NEVER commit .env files to git — they contain secrets.
# ═══════════════════════════════════════════════════════════

# ── Ritual Chain ──
# Public RPC endpoint (default public endpoint — works for read-only and subscriptions)
RITUAL_RPC_URL=https://rpc.ritualfoundation.org
# WebSocket endpoint for real-time event indexing (optional — falls back to RPC_URL with /ws)
RITUAL_WSS_URL=wss://rpc.ritualfoundation.org/ws

# ── VAPID Keys (REQUIRED for push notifications) ──
# Generate a fresh pair:
#   node service/setup-keys.js
# The public key must also be updated in js/notify.js (VAPID_PUBLIC_KEY constant).
VAPID_PUBLIC_KEY=__GENERATE_YOUR_OWN__
VAPID_PRIVATE_KEY=__GENERATE_YOUR_OWN__
VAPID_SUBJECT=mailto:lastsignal@example.com

# ── Email transport (OPTIONAL — leave blank for dev mode with Ethereal Email) ──
# Any SMTP provider works. Examples:
#   SMTP2GO:  mail.smtp2go.com:2525
#   Mailgun:  smtp.mailgun.org:587
#   Mailjet:  in-v3.mailjet.net:587
#   SendGrid: smtp.sendgrid.net:587
#SMTP_HOST=mail.smtp2go.com
#SMTP_PORT=2525
#SMTP_SECURE=false
#SMTP_USER=
#SMTP_PASS=
SMTP_FROM=LastSignal <noreply@lastsignal.xyz>

# Legacy SendGrid (only used if SMTP_HOST is not set):
#SENDGRID_API_KEY=__REPLACE_OR_LEAVE_EMPTY__
